# -- Database ---------------------------------------------------------------
DB_USER=migration_user
# REQUIRED: Set a strong password. The server will refuse to start with the default value.
DB_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
DB_NAME=migration_db
# DB_HOST and DB_PORT are set automatically inside Docker Compose.
# Override only when running the backend outside Docker.
# DB_HOST=localhost
# DB_PORT=5432

# -- Backend ----------------------------------------------------------------
# REQUIRED: Use at least 32 random characters. Generate with: openssl rand -hex 32
# The server will refuse to start with the default value.
JWT_SECRET=REPLACE_WITH_STRONG_SECRET
BACKEND_PORT=4000

# -- CORS -------------------------------------------------------------------
# Set to the exact origin of your frontend in production (e.g. https://app.example.com)
ALLOWED_ORIGIN=http://localhost:3000

# -- Frontend ---------------------------------------------------------------
FRONTEND_PORT=3000

# URL of the backend API as seen from the browser.
# In production this should be an HTTPS URL behind a reverse proxy.
VITE_API_URL=http://localhost:4000
