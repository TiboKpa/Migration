# ── Database ──────────────────────────────────────────────────────────────────
DB_USER=migration_user
DB_PASSWORD=change_me
DB_NAME=migration_db
# DB_HOST and DB_PORT are set automatically inside Docker Compose.
# Override only when running the backend outside Docker.
# DB_HOST=localhost
# DB_PORT=5432

# ── Backend ───────────────────────────────────────────────────────────────────
# Secret used to sign JWT tokens. Use a long random string in production.
JWT_SECRET=change_me_jwt_secret
BACKEND_PORT=4000

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_PORT=3000

# URL of the backend API as seen from the browser.
# In Docker Compose this is typically http://<your-server-ip>:4000
# In local dev (Vite proxy) you can leave this as http://localhost:4000
VITE_API_URL=http://localhost:4000
